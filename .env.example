# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#
# Один и тот же .env используется для docker-compose.java.yml и docker-compose.go.yml —
# запускается всегда только один стек за раз.

# --- HTTPS ---
# true  — nginx поднимает HTTPS (443) с самоподписанным сертификатом (генерируется
#         автоматически при первом запуске, если не смонтированы свои certs) и
#         редиректит HTTP (80) на HTTPS.
# false — только обычный HTTP (80).
ENABLE_HTTPS=false

# Порты на хосте, которые проброшены наружу (слушает только nginx).
HTTP_PORT=80
HTTPS_PORT=443

# --- PostgreSQL ---
POSTGRES_DB=crypto_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Backend (общее для Java и Go сервисов) ---
# Пароль PKCS12-хранилища RSA-ключей. Обязателен, не имеет дефолта —
# без него контейнер backend не запустится.
CRYPTO_KEYSTORE_PASSWORD=change-me-strong-password
