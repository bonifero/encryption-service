# Только для локальной разработки (npm run dev), не используется в production-сборке
# (в контейнере фронтенд всегда обращается по относительному /api — прокси делает nginx).
# Куда проксировать /api при локальном запуске без Docker:
# Java-бэкенд слушает :8080, Go-бэкенд — :8081.
VITE_API_PROXY_TARGET=http://localhost:8080
